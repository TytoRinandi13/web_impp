generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Department {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  description String?
  members     Member[]
  programs    WorkProgram[]
  agendas     Agenda[]
}

model Position {
  id      String   @id @default(cuid())
  name    String   
  level   Int      @default(1)
  members Member[]
}

model Member {
  id            String     @id @default(cuid())
  name          String
  prodi         String     
  batch         Int        
  birth_date    DateTime   
  image_url     String?
  department_id String
  position_id   String
  department    Department @relation(fields: [department_id], references: [id])
  position      Position   @relation(fields: [position_id], references: [id])
  instagram     String?
  linkedin      String?
}

model WorkProgram {
  id            String     @id @default(cuid())
  title         String
  description   String?
  execution_date DateTime
  status String @default("BELUM") // BELUM, SELESAI, BATAL
  department_id String
  department    Department @relation(fields: [department_id], references: [id])
}

model Agenda {
  id            String     @id @default(cuid())
  title         String
  frequency     String     // WEEKLY, MONTHLY, YEARLY
  department_id String
  department    Department @relation(fields: [department_id], references: [id])
}